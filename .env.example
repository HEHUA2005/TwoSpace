# 将此文件复制为 .env 并填写真实值
# cp .env.example .env

SECRET_KEY=replace-with-a-long-random-string

# 用户1
USER1_NAME=她
USER1_AVATAR=/uploads/avatar1.jpg
# 生成密码哈希：python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
USER1_PASSWORD_HASH=

# 用户2
USER2_NAME=我
USER2_AVATAR=/uploads/avatar2.jpg
USER2_PASSWORD_HASH=

# 恋爱开始日期（YYYY-MM-DD）
LOVE_START_DATE=2024-01-01

# 合照路径（放在 data/uploads/ 下）
COUPLE_PHOTO=/uploads/couple.jpg

# 自定义语录，用 | 分隔（留空使用默认）
QUOTES=

UPLOAD_DIR=xxx/data/uploads # 让后端的 uploads 目录指向 data/uploads， 默认在backend/uploads， 但实际存放在data/uploads， 需要配置这个路径让后端能找到图片
# 你的域名
DOMAIN=example.com
